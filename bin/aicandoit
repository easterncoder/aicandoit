set -euo pipefail

_CURSOR_DEFAULT="gpt-5.3-codex-high"
AUTO_BRANCH_PREFIX="auto"
AUTO_BRANCH_FILE_MAX_BYTES="${AUTO_BRANCH_FILE_MAX_BYTES:-65536}"
AUTO_BRANCH_FILE_SNIPPET_BYTES="${AUTO_BRANCH_FILE_SNIPPET_BYTES:-512}"
AUTO_BRANCH_NAME_MAX="${AUTO_BRANCH_NAME_MAX:-48}"
ARTIFACT_ROOT_DEFAULT=".aicandoit"

# Print usage and exit.
usage() {
  cat >&2 <<EOF
Usage: aicandoit --coder <cli[/model]> --reviewer <cli[/model]> [--planner <cli[/model]>] [--mode <stage>] [--worktree] [--branch <name> | --current-branch | --auto-branch] <prompt...>

Options:
  -C, --coder <cli[/model]>      Coder CLI: claude, codex, cursor, or gemini; optionally append /model (required)
  -R, --reviewer <cli[/model]>   Reviewer CLI: claude, codex, cursor, or gemini; optionally append /model; must differ from --coder and --planner by CLI or effective model (required)
  -P, --planner <cli[/model]>    Planner CLI: claude, codex, cursor, or gemini; optionally append /model; defaults to --coder
  -M, --mode <stage>             Stage to run: plan, plan-review, code, or code-review; defaults to full workflow
  -W, --worktree                 Run on a branch worktree instead of switching the source checkout
      --verbose                  Show CLI tool output (stderr merged to stdout)
  -B, --branch <name>            Branch to switch to or create; optional when current-branch inference succeeds
      --current-branch           Use the current git branch; optional when current-branch inference succeeds
      --auto-branch              Derive a new branch name from the prompt before branch creation
EOF
  exit 1
}

# Split a cli[/model] string into CLI and model parts.
split_cli_model() {
  local value="$1"
  local cli_var="$2"
  local model_var="$3"

  if [[ "$value" == */* ]]; then
    printf -v "$cli_var" '%s' "${value%%/*}"
    printf -v "$model_var" '%s' "${value#*/}"
  else
    printf -v "$cli_var" '%s' "$value"
    printf -v "$model_var" '%s' ""
  fi
}

# Validate cli[/model] formatting when a slash is present.
validate_cli_model() {
  local flag="$1"
  local value="$2"
  local cli="$3"
  local model="$4"

  if [[ "$value" == */* ]]; then
    [[ -z "$cli" ]] && { echo "error: $flag CLI part cannot be empty" >&2; usage; }
    [[ -z "$model" ]] && { echo "error: $flag model part cannot be empty when slash is used" >&2; usage; }
    [[ "$model" == */* ]] && { echo "error: $flag value may only contain one slash (cli/model)" >&2; usage; }
  fi
  return 0
}

# Normalize a model string for CLI comparison.
effective_model() {
  local cli="$1"
  local model="$2"

  if [[ "$cli" == "cursor" ]]; then
    printf '%s' "${model:-$_CURSOR_DEFAULT}"
  else
    printf '%s' "$model"
  fi
}

# Build model args for CLIs that support --model.
build_model_args() {
  local model="$1"
  local -n claude_args="$2"
  local -n codex_args="$3"
  local -n gemini_args="$4"

  if [[ -n "$model" ]]; then
    claude_args=(--model "$model")
    codex_args=(--model "$model")
    gemini_args=(--model "$model")
  else
    claude_args=()
    codex_args=()
    gemini_args=()
  fi
}

# Build cursor args with the default model.
build_cursor_args() {
  local model="$1"
  local -n cursor_args="$2"

  cursor_args=(--trust --print --model "${model:-$_CURSOR_DEFAULT}")
}

# Hash a branch name using deterministic tool fallback order.
hash_branch_name() {
  local branch="$1"
  local digest=""

  if command -v sha256sum >/dev/null 2>&1; then
    digest="$(printf '%s' "$branch" | sha256sum 2>/dev/null | awk '{print $1}' || true)"
  fi
  if [[ -z "$digest" ]] && command -v shasum >/dev/null 2>&1; then
    digest="$(printf '%s' "$branch" | shasum -a 256 2>/dev/null | awk '{print $1}' || true)"
  fi
  if [[ -z "$digest" ]] && command -v openssl >/dev/null 2>&1; then
    digest="$(printf '%s' "$branch" | openssl dgst -sha256 2>/dev/null | awk '{print $NF}' || true)"
  fi

  if [[ -z "$digest" ]]; then
    echo "error: branch slug hashing requires sha256sum, shasum, or openssl" >&2
    return 1
  fi

  printf '%s\n' "$digest"
}

# Resolve the legacy branch slug used before collision-safe hashing.
legacy_branch_to_slug() {
  local branch="$1"

  printf '%s\n' "${branch//\//_}"
}

# Resolve the branch slug used by branch-scoped artifact paths.
branch_to_slug() {
  local branch="$1"
  local base=""
  local digest=""
  local suffix=""

  base="$(printf '%s' "$branch" | tr '/' '_' | sed -E 's/[^A-Za-z0-9._-]+/-/g; s/^-+//; s/-+$//; s/-{2,}/-/g')"
  if [[ -z "$base" ]]; then
    base="branch"
  fi

  digest="$(hash_branch_name "$branch")"
  suffix="$(printf '%s' "$digest" | cut -c1-10)"

  printf '%s-%s\n' "$base" "$suffix"
}

# Resolve the branch artifact slug, preserving compatibility with legacy paths.
resolve_branch_artifact_slug() {
  local branch="$1"
  local artifact_root="${2:-.aicandoit}"
  local branch_path=""
  local legacy_path=""

  branch_path="$(branch_to_slug "$branch")"
  if [[ -d "${artifact_root}/branches/${branch_path}" ]]; then
    legacy_path="$(legacy_branch_to_slug "$branch")"
    if [[ -d "${artifact_root}/branches/${legacy_path}" ]] && ! branch_artifact_dir_has_primary_files "$artifact_root" "$branch_path" && branch_artifact_dir_has_primary_files "$artifact_root" "$legacy_path"; then
      printf '%s\n' "$legacy_path"
      return 0
    fi
    printf '%s\n' "$branch_path"
    return 0
  fi

  legacy_path="$(legacy_branch_to_slug "$branch")"
  if [[ -d "${artifact_root}/branches/${legacy_path}" ]]; then
    printf '%s\n' "$legacy_path"
    return 0
  fi

  printf '%s\n' "$branch_path"
}

# Detect whether a branch artifact directory contains primary planning artifacts.
branch_artifact_dir_has_primary_files() {
  local artifact_root="$1"
  local branch_path="$2"
  local branch_dir="${artifact_root}/branches/${branch_path}"

  [[ -f "${branch_dir}/plan.md" ]] && return 0
  [[ -f "${branch_dir}/plan-review.md" ]] && return 0
  [[ -f "${branch_dir}/code-review.md" ]] && return 0
  [[ -f "${branch_dir}/code-fix.md" ]] && return 0
  [[ -d "${branch_dir}/context" ]] && return 0

  return 1
}

# Resolve the current branch name without requiring an existing commit.
resolve_current_branch_name() {
  local branch=""
  local git_dir_args=()

  if [[ $# -gt 0 && -n "$1" ]]; then
    git_dir_args=(-C "$1")
  fi

  branch="$(git "${git_dir_args[@]}" branch --show-current 2>/dev/null || true)"
  if [[ -n "$branch" ]]; then
    printf '%s\n' "$branch"
    return 0
  fi

  branch="$(git "${git_dir_args[@]}" symbolic-ref --quiet --short HEAD 2>/dev/null || true)"
  if [[ -n "$branch" ]]; then
    printf '%s\n' "$branch"
    return 0
  fi

  git "${git_dir_args[@]}" rev-parse --abbrev-ref HEAD
}

# Check whether the source checkout has uncommitted changes.
source_checkout_has_uncommitted_changes() {
  local source_checkout_path="$1"

  [[ -n "$(git -C "$source_checkout_path" status --porcelain)" ]]
}

# Guard non-worktree branch switching when the source checkout is dirty.
guard_dirty_non_worktree_branch_switch() {
  local source_checkout_path="$1"
  local target_branch="$2"
  local current_branch=""
  local branch_exists=false

  current_branch="$(resolve_current_branch_name "$source_checkout_path")"

  if [[ "$current_branch" == "$target_branch" ]]; then
    return 0
  fi

  if ! source_checkout_has_uncommitted_changes "$source_checkout_path"; then
    return 0
  fi

  if git -C "$source_checkout_path" show-ref --verify --quiet "refs/heads/$target_branch"; then
    branch_exists=true
  fi

  if [[ "$branch_exists" == true ]]; then
    echo "error: source checkout has uncommitted changes; cannot switch from '$current_branch' to '$target_branch' without --worktree" >&2
  else
    echo "error: source checkout has uncommitted changes; cannot create and switch to '$target_branch' without --worktree" >&2
  fi
  echo "hint: commit or stash changes, use --current-branch, or run with --worktree" >&2
  exit 1
}

# Check whether a branch artifact directory exists under the given root.
branch_artifact_dir_exists() {
  local artifact_root="$1"
  local branch_path="$2"

  [[ -d "${artifact_root}/branches/${branch_path}" ]]
}

# Resolve the canonical repository root from the shared git directory.
resolve_repo_root() {
  local common_git_dir=""

  common_git_dir="$(git rev-parse --path-format=absolute --git-common-dir)"
  (
    cd "${common_git_dir}/.."
    pwd -P
  )
}

# Reduce arbitrary text to a branch-safe slug component.
sanitize_branch_component() {
  local value="$1"
  local limit="${2:-$AUTO_BRANCH_NAME_MAX}"
  local sanitized=""

  sanitized="$(printf '%s' "$value" | tr '[:upper:]' '[:lower:]' | sed -E 's/[^a-z0-9]+/-/g; s/^-+//; s/-+$//; s/-{2,}/-/g')"
  if [[ -z "$sanitized" ]]; then
    sanitized="item"
  fi

  sanitized="$(printf '%s' "$sanitized" | cut -c1-"$limit" | sed -E 's/-+$//')"
  if [[ -z "$sanitized" ]]; then
    sanitized="item"
  fi

  printf '%s\n' "$sanitized"
}

# Append a deterministic numeric suffix when a local branch already exists.
resolve_unique_local_branch_name() {
  local candidate="$1"
  local suffix=2
  local unique="$candidate"

  while git show-ref --verify --quiet "refs/heads/$unique"; do
    unique="${candidate}-${suffix}"
    suffix=$((suffix + 1))
  done

  printf '%s\n' "$unique"
}

# Extract the first issue number reference from a prompt.
extract_issue_number_from_prompt() {
  local prompt="$1"

  if [[ "$prompt" =~ (^|[^[:alnum:]])gh[[:space:]]+issue[[:space:]]+([0-9]+)([^[:digit:]]|$) ]]; then
    printf '%s\n' "${BASH_REMATCH[2]}"
    return 0
  fi

  if [[ "$prompt" =~ (^|[^[:alnum:]])issue[[:space:]]+([0-9]+)([^[:digit:]]|$) ]]; then
    printf '%s\n' "${BASH_REMATCH[2]}"
    return 0
  fi

  return 1
}

# Resolve an issue title from a fixture variable or gh.
fetch_issue_title() {
  local issue_number="$1"
  local fixture_var="AICANDOIT_ISSUE_TITLE_${issue_number}"
  local fixture_value="${!fixture_var-}"
  local title=""

  if [[ -n "$fixture_value" ]]; then
    printf '%s\n' "$fixture_value"
    return 0
  fi

  title="$(gh issue view "$issue_number" --json title --jq .title 2>/dev/null || true)"
  if [[ -n "$title" ]]; then
    printf '%s\n' "$title"
    return 0
  fi

  return 1
}

# Build an issue-derived branch name.
build_issue_branch_name() {
  local issue_number="$1"
  local title="$2"
  local title_slug=""
  local candidate=""

  title_slug="$(sanitize_branch_component "$title" 36)"
  candidate="${AUTO_BRANCH_PREFIX}/issue-${issue_number}"
  if [[ -n "$title_slug" && "$title_slug" != "item" ]]; then
    candidate="${candidate}-${title_slug}"
  fi

  printf '%s\n' "$candidate"
}

# Trim prompt token wrappers before testing it as a file path.
normalize_prompt_path_token() {
  local token="$1"
  local first_char=""
  local last_char=""

  while [[ -n "$token" ]]; do
    first_char="${token:0:1}"
    if [[ "$first_char" == '"' || "$first_char" == "'" || "$first_char" == '`' || "$first_char" == '(' || "$first_char" == '<' || "$first_char" == '[' ]]; then
        token="${token#?}"
    else
      break
    fi
  done

  while [[ -n "$token" ]]; do
    last_char="${token: -1}"
    if [[ "$last_char" == '"' || "$last_char" == "'" || "$last_char" == '`' || "$last_char" == ')' || "$last_char" == ',' || "$last_char" == '.' || "$last_char" == ';' || "$last_char" == ':' || "$last_char" == '!' || "$last_char" == '?' || "$last_char" == ']' || "$last_char" == '}' || "$last_char" == '>' ]]; then
      token="${token%?}"
    else
      break
    fi
  done

  printf '%s\n' "$token"
}

# Determine whether a prompt token looks like a file path.
looks_like_path_candidate() {
  local token="$1"

  [[ "$token" == */* || "$token" == .* || "$token" == *.* ]]
}

# Resolve a prompt file candidate to a readable repo-local file.
resolve_repo_local_file() {
  local repo_root="$1"
  local candidate="$2"
  local resolved_dir=""
  local resolved_path=""

  [[ -n "$candidate" ]] || return 1

  if [[ "$candidate" == /* ]]; then
    resolved_path="$candidate"
  else
    resolved_dir="$(cd "$repo_root" && cd "$(dirname "$candidate")" 2>/dev/null && pwd -P)" || return 1
    resolved_path="${resolved_dir}/$(basename "$candidate")"
  fi

  [[ -f "$resolved_path" ]] || return 1
  [[ "$resolved_path" == "$repo_root" || "$resolved_path" == "$repo_root"/* ]] || return 1

  printf '%s\n' "$resolved_path"
}

# Find the first repo-local file reference inside a prompt.
extract_prompt_file_reference() {
  local prompt="$1"
  local repo_root="$2"
  local token=""
  local candidate=""
  local resolved_path=""

  for token in $prompt; do
    candidate="$(normalize_prompt_path_token "$token")"
    if ! looks_like_path_candidate "$candidate"; then
      continue
    fi
    resolved_path="$(resolve_repo_local_file "$repo_root" "$candidate" 2>/dev/null || true)"
    if [[ -n "$resolved_path" ]]; then
      printf '%s\n' "$resolved_path"
      return 0
    fi
  done

  return 1
}

# Enforce the maximum readable file size for auto-branch resolution.
file_within_auto_branch_limit() {
  local path="$1"
  local size="0"

  size="$(wc -c < "$path")"
  [[ "$size" -le "$AUTO_BRANCH_FILE_MAX_BYTES" ]]
}

# Detect whether a file should be treated as text.
is_probably_text_file() {
  local path="$1"

  LC_ALL=C grep -Iq . "$path" || [[ ! -s "$path" ]]
}

# Read a stable leading snippet from a text file.
read_auto_branch_file_snippet() {
  local path="$1"

  head -c "$AUTO_BRANCH_FILE_SNIPPET_BYTES" "$path"
}

# Select the first non-empty line from a file snippet.
extract_file_context_line() {
  local snippet="$1"
  local line=""

  while IFS= read -r line; do
    line="$(printf '%s' "$line" | sed -E 's/^[[:space:]]+//; s/[[:space:]]+$//')"
    if [[ -n "$line" ]]; then
      printf '%s\n' "$line"
      return 0
    fi
  done <<< "$snippet"

  return 1
}

# Build a file-derived branch name from basename and leading text.
build_file_branch_name() {
  local path="$1"
  local snippet="$2"
  local basename_slug=""
  local context_line=""
  local context_slug=""
  local candidate=""

  basename_slug="$(sanitize_branch_component "$(basename "$path")" 18)"
  context_line="$(extract_file_context_line "$snippet" 2>/dev/null || true)"
  context_slug="$(sanitize_branch_component "$context_line" 28)"
  candidate="${AUTO_BRANCH_PREFIX}/${basename_slug}"

  if [[ -n "$context_line" && "$context_slug" != "item" ]]; then
    candidate="${candidate}-${context_slug}"
  fi

  printf '%s\n' "$candidate"
}

# Build a prompt-derived fallback branch name.
build_prompt_branch_name() {
  local prompt="$1"
  local prompt_slug=""

  prompt_slug="$(sanitize_branch_component "$prompt" 48)"
  printf '%s/%s\n' "$AUTO_BRANCH_PREFIX" "$prompt_slug"
}

# Resolve a deterministic branch name from issue, file, or prompt text.
resolve_auto_branch_name() {
  local prompt="$1"
  local repo_root="$2"
  local issue_number=""
  local issue_title=""
  local file_path=""
  local snippet=""
  local candidate=""

  issue_number="$(extract_issue_number_from_prompt "$prompt" 2>/dev/null || true)"
  if [[ -n "$issue_number" ]]; then
    issue_title="$(fetch_issue_title "$issue_number" 2>/dev/null || true)"
    candidate="$(build_issue_branch_name "$issue_number" "$issue_title")"
    resolve_unique_local_branch_name "$candidate"
    return 0
  fi

  file_path="$(extract_prompt_file_reference "$prompt" "$repo_root" 2>/dev/null || true)"
  if [[ -n "$file_path" ]] && file_within_auto_branch_limit "$file_path" && is_probably_text_file "$file_path"; then
    snippet="$(read_auto_branch_file_snippet "$file_path")"
    candidate="$(build_file_branch_name "$file_path" "$snippet")"
    resolve_unique_local_branch_name "$candidate"
    return 0
  fi

  candidate="$(build_prompt_branch_name "$prompt")"
  resolve_unique_local_branch_name "$candidate"
}

# Determine whether the selected mode requires a non-empty prompt.
prompt_required_for_mode() {
  local mode="$1"

  [[ "$mode" == "all" || "$mode" == "plan" ]]
}

# Resolve the final target branch before checkout or worktree handling.
resolve_target_branch_name() {
  local current_branch=""
  local current_branch_path=""
  local repo_root=""

  if [[ "$AUTO_BRANCH" == true ]]; then
    repo_root="$(resolve_repo_root)"
    BRANCH="$(resolve_auto_branch_name "$PROMPT" "$repo_root")"
    return 0
  fi

  if [[ -n "$BRANCH" ]]; then
    return 0
  fi

  current_branch="$(resolve_current_branch_name)"
  if [[ "$current_branch" == "HEAD" ]]; then
    current_branch="detached-$(git rev-parse --short HEAD)"
  fi

  if [[ "$USE_CURRENT_BRANCH" == true ]]; then
    BRANCH="$current_branch"
    return 0
  fi

  current_branch_path="$(resolve_branch_artifact_slug "$current_branch" "$ARTIFACT_ROOT_DEFAULT")"
  if branch_artifact_dir_exists "$ARTIFACT_ROOT_DEFAULT" "$current_branch_path"; then
    USE_CURRENT_BRANCH=true
    BRANCH="$current_branch"
    return 0
  fi

  echo "error: pass --branch <name>, --current-branch, or --auto-branch" >&2
  usage
}

# Check that a CLI name is supported.
valid_cli() {
  [[ "$1" == "claude" || "$1" == "codex" || "$1" == "cursor" || "$1" == "gemini" ]]
}

# Ensure branch-scoped logging paths are initialized before command execution.
ensure_logging_context() {
  if [[ "${LOG_CONTEXT_READY:-false}" == true ]]; then
    return 0
  fi

  local branch_name="${BRANCH:-}"

  if [[ -z "${ARTIFACT_ROOT:-}" ]]; then
    ARTIFACT_ROOT="$ARTIFACT_ROOT_DEFAULT"
  fi

  if [[ -z "$branch_name" ]]; then
    branch_name="$(resolve_current_branch_name)"
    BRANCH="$branch_name"
  fi

  if [[ -z "${BRANCH_PATH:-}" ]]; then
    BRANCH_PATH="$(resolve_branch_artifact_slug "$branch_name" "$ARTIFACT_ROOT")"
  fi

  LOG_DIR="${ARTIFACT_ROOT}/branches/${BRANCH_PATH}/logs"
  mkdir -p "$LOG_DIR"
  LOG_CONTEXT_READY=true
}

# Return the next deterministic sequence number for a role/action log key.
next_log_sequence() {
  local key="$1"
  local current=0
  local next=0

  if ! declare -p LOG_SEQUENCE_COUNTER >/dev/null 2>&1; then
    declare -gA LOG_SEQUENCE_COUNTER=()
  fi

  current="${LOG_SEQUENCE_COUNTER[$key]:-0}"
  next=$((current + 1))
  LOG_SEQUENCE_COUNTER["$key"]="$next"
  LOG_SEQUENCE_VALUE="$(printf '%03d' "$next")"

  printf '%s\n' "$LOG_SEQUENCE_VALUE"
}

# Build a deterministic branch-scoped log filename for a role/action execution.
build_log_file_path() {
  local role="$1"
  local action="$2"
  local key=""

  ensure_logging_context
  key="${role}-${action}"
  next_log_sequence "$key" >/dev/null

  LOG_FILE_PATH="${LOG_DIR}/${role}-${action}-${LOG_SEQUENCE_VALUE}.log"
}

# Run a CLI command without output routing logic.
run_cli() {
  "$@"
}

# Run a CLI command and persist combined output to the provided log file.
run_cli_logged() {
  local log_file="$1"
  shift

  if [[ "$VERBOSE" == true ]]; then
    run_cli "$@" 2>&1 | tee -a "$log_file"
  else
    run_cli "$@" >>"$log_file" 2>&1
  fi
}

# Run a role/action command through the selected CLI.
run_role_action() {
  local role="$1"
  local action="$2"
  local continue_mode="$3"
  local log_action="$action"
  local log_file=""
  local cli=""
  local model_args_name=""
  local cursor_args_name=""
  local prompt=""
  local codex_prompt=""

  case "$role" in
    planner)
      cli="$PLANNER_CLI"
      cursor_args_name="PLANNER_CURSOR_ARGS"
      case "$cli" in
        claude) model_args_name="PLANNER_CLAUDE_MODEL" ;;
        codex) model_args_name="PLANNER_CODEX_MODEL" ;;
        gemini) model_args_name="PLANNER_GEMINI_MODEL" ;;
      esac
      ;;
    coder)
      cli="$CODER_CLI"
      cursor_args_name="CODER_CURSOR_ARGS"
      case "$cli" in
        claude) model_args_name="CODER_CLAUDE_MODEL" ;;
        codex) model_args_name="CODER_CODEX_MODEL" ;;
        gemini) model_args_name="CODER_GEMINI_MODEL" ;;
      esac
      ;;
    reviewer)
      cli="$REVIEWER_CLI"
      cursor_args_name="REVIEWER_CURSOR_ARGS"
      case "$cli" in
        claude) model_args_name="REVIEWER_CLAUDE_MODEL" ;;
        codex) model_args_name="REVIEWER_CODEX_MODEL" ;;
        gemini) model_args_name="REVIEWER_GEMINI_MODEL" ;;
      esac
      ;;
  esac

  case "$action" in
    plan)
      prompt="/plan-it $PROMPT"
      codex_prompt="\$plan-it $PROMPT"
      ;;
    plan-update)
      prompt="/plan-update"
      codex_prompt='$plan-update'
      ;;
    code)
      prompt="/code-it"
      codex_prompt='$code-it'
      ;;
    code-fix)
      prompt="/code-fix"
      codex_prompt='$code-fix'
      ;;
    plan-review)
      prompt="/plan-review"
      codex_prompt='$plan-review'
      ;;
    code-review)
      prompt="/code-review"
      codex_prompt='$code-review'
      ;;
  esac

  if [[ "${REVIEW_LOOP_ATTEMPT:-0}" -gt 0 ]]; then
    case "$action" in
      plan-update|code-fix|plan-review|code-review)
        log_action="${action}-loop"
        ;;
    esac
  fi

  build_log_file_path "$role" "$log_action"
  log_file="$LOG_FILE_PATH"

  case "$cli" in
    claude)
      local -n claude_model_args="$model_args_name"
      if [[ "$continue_mode" == true ]]; then
        run_cli_logged "$log_file" claude "${claude_model_args[@]}" -c -p "$prompt"
      else
        run_cli_logged "$log_file" claude "${claude_model_args[@]}" -p "$prompt"
      fi
      ;;
    codex)
      local -n codex_model_args="$model_args_name"
      if [[ "$continue_mode" == true ]]; then
        run_cli_logged "$log_file" codex $CODEX_BASE_ARGS "${codex_model_args[@]}" exec resume --last "$codex_prompt"
      else
        run_cli_logged "$log_file" codex $CODEX_BASE_ARGS "${codex_model_args[@]}" exec "$codex_prompt"
      fi
      ;;
    cursor)
      local -n cursor_args="$cursor_args_name"
      if [[ "$continue_mode" == true ]]; then
        run_cli_logged "$log_file" cursor-agent "${cursor_args[@]}" --continue "$prompt"
      else
        run_cli_logged "$log_file" cursor-agent "${cursor_args[@]}" "$prompt"
      fi
      ;;
    gemini)
      local -n gemini_model_args="$model_args_name"
      if [[ "$continue_mode" == true ]]; then
        run_cli_logged "$log_file" gemini "${gemini_model_args[@]}" --resume latest --prompt "$prompt"
      else
        run_cli_logged "$log_file" gemini "${gemini_model_args[@]}" --prompt "$prompt"
      fi
      ;;
  esac
}

# Run the initial plan step using the planner role.
run_plan() {
  run_role_action planner plan false
}

# Update the plan using the planner role.
run_plan_update() {
  run_role_action planner plan-update true
}

# Run the code step using the coder role.
run_code() {
  if [[ "$PLANNER_MATCHES_CODER" == true ]]; then
    run_role_action coder code true
  else
    run_role_action coder code false
  fi
}

# Run the code fix step using the coder role.
run_code_fix() {
  run_role_action coder code-fix true
}

# Run the initial plan review using the reviewer role.
run_plan_review() {
  run_role_action reviewer plan-review false
}

# Re-run plan review in the review loop using the reviewer role.
run_plan_review_loop() {
  run_role_action reviewer plan-review true
}

# Run the initial code review using the reviewer role.
run_code_review() {
  run_role_action reviewer code-review true
}

# Re-run code review in the review loop using the reviewer role.
run_code_review_loop() {
  run_role_action reviewer code-review true
}

# Run the review loop until the review file is marked ALL GOOD.
review_loop() {
  local label="$1"
  local file="$2"
  local update_fn="$3"
  local review_fn="$4"
  local updater="$5"
  local tries=0

  REVIEW_LOOP_ATTEMPT=0
  echo "$label review loop started..."
  until [[ -f "$file" ]] && grep -q 'ALL GOOD' "$file"; do
    tries=$((tries + 1))
    REVIEW_LOOP_ATTEMPT="$tries"
    if (( tries >= MAX_TRIES )); then
      echo "Gave up after $MAX_TRIES tries (no 'ALL GOOD' in $file)" >&2
      exit 2
    fi
    echo "- Loop: $tries"
    echo "- $updater is updating $label..."
    "$update_fn"
    echo "- Reviewer is re-checking $label..."
    "$review_fn"
    sleep "$SLEEP_SECS"
  done
  REVIEW_LOOP_ATTEMPT=0
  echo "$label is good!"
}

# Resolve the default branch start ref with remote HEAD and local defaults.
resolve_default_start_ref() {
  local default_branch=""
  local start_ref=""

  default_branch="$(git symbolic-ref --quiet --short refs/remotes/origin/HEAD | sed 's@^origin/@@')"
  if [[ -n "$default_branch" ]]; then
    printf 'origin/%s\n' "$default_branch"
    return 0
  fi

  if git show-ref --verify --quiet refs/remotes/origin/main; then
    start_ref="origin/main"
  elif git show-ref --verify --quiet refs/heads/main; then
    start_ref="main"
  elif git show-ref --verify --quiet refs/remotes/origin/master; then
    start_ref="origin/master"
  elif git show-ref --verify --quiet refs/heads/master; then
    start_ref="master"
  elif git show-ref --verify --quiet refs/remotes/origin/develop; then
    start_ref="origin/develop"
  elif git show-ref --verify --quiet refs/heads/develop; then
    start_ref="develop"
  else
    start_ref="main"
  fi

  printf '%s\n' "$start_ref"
}

# Build the default deterministic worktree path from repo root and branch name.
resolve_worktree_path() {
  local repo_root="$1"
  local branch="$2"
  local branch_path=""

  branch_path="$(branch_to_slug "$branch")"

  printf '%s/.aicandoit/branches/%s/worktree\n' "$repo_root" "$branch_path"
}

# Check whether a path is a registered worktree for a branch.
is_registered_worktree_for_branch() {
  local worktree_path="$1"
  local branch="$2"
  local branch_ref="refs/heads/$branch"

  git worktree list --porcelain | awk -v want_path="$worktree_path" -v want_branch="$branch_ref" '
    BEGIN { RS=""; FS="\n"; found=0 }
    {
      path=""
      branch=""
      for (i = 1; i <= NF; i++) {
        if ($i ~ /^worktree /) {
          path=substr($i, 10)
        } else if ($i ~ /^branch /) {
          branch=substr($i, 8)
        }
      }
      if (path == want_path && branch == want_branch) {
        found=1
      }
    }
    END { exit found ? 0 : 1 }
  '
}

# Ensure the target branch worktree exists and is valid.
ensure_worktree_for_branch() {
  local branch="$1"
  local worktree_path="$2"
  local start_ref="$3"
  local source_checkout_path="$4"

  if [[ -e "$worktree_path" ]]; then
    if is_registered_worktree_for_branch "$worktree_path" "$branch"; then
      return 0
    fi
    echo "error: worktree path exists but is not a valid registered worktree for '$branch': $worktree_path" >&2
    exit 1
  fi

  if [[ "$(resolve_current_branch_name "$source_checkout_path")" == "$branch" ]]; then
    echo "error: target branch '$branch' is checked out in the source checkout; switch source checkout first or run without --worktree" >&2
    exit 1
  fi

  mkdir -p "$(dirname "$worktree_path")"
  if git show-ref --verify --quiet "refs/heads/$branch"; then
    git worktree add "$worktree_path" "$branch"
  else
    git worktree add -b "$branch" "$worktree_path" "$start_ref"
  fi
}

# Parse the launcher arguments into global state.
parse_args() {
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --coder|-C)
        [[ $# -gt 1 ]] || { echo "error: --coder requires a value" >&2; usage; }
        CODER="$2"; shift 2 ;;
      --reviewer|-R)
        [[ $# -gt 1 ]] || { echo "error: --reviewer requires a value" >&2; usage; }
        REVIEWER="$2"; shift 2 ;;
      --planner|-P)
        [[ $# -gt 1 ]] || { echo "error: --planner requires a value" >&2; usage; }
        PLANNER="$2"; shift 2 ;;
      --mode|-M)
        [[ $# -gt 1 ]] || { echo "error: --mode requires a value" >&2; usage; }
        MODE="$2"; MODE_SET=true; shift 2 ;;
      --worktree|-W) USE_WORKTREE=true; shift ;;
      --verbose) VERBOSE=true; shift ;;
      --branch|-B)
        [[ $# -gt 1 ]] || { echo "error: --branch requires a value" >&2; usage; }
        BRANCH="$2"; shift 2 ;;
      --current-branch) USE_CURRENT_BRANCH=true; shift ;;
      --auto-branch) AUTO_BRANCH=true; shift ;;
      --) shift; break ;;
      -*) echo "error: unknown option: $1" >&2; usage ;;
      *)  break ;;
    esac
  done

  PROMPT="$*"
}

# Validate the parsed arguments before running the workflow.
validate_args() {
  if [[ -z "$PLANNER" ]]; then
    PLANNER="$CODER"
  fi

  split_cli_model "$CODER" CODER_CLI CODER_MODEL
  split_cli_model "$PLANNER" PLANNER_CLI PLANNER_MODEL
  split_cli_model "$REVIEWER" REVIEWER_CLI REVIEWER_MODEL

  validate_cli_model --coder "$CODER" "$CODER_CLI" "$CODER_MODEL"
  validate_cli_model --planner "$PLANNER" "$PLANNER_CLI" "$PLANNER_MODEL"
  validate_cli_model --reviewer "$REVIEWER" "$REVIEWER_CLI" "$REVIEWER_MODEL"

  if ! valid_cli "$CODER_CLI"; then
    echo "error: --coder must be claude, codex, cursor, or gemini (got: $CODER_CLI)" >&2
    usage
  fi
  if ! valid_cli "$PLANNER_CLI"; then
    echo "error: --planner must be claude, codex, cursor, or gemini (got: $PLANNER_CLI)" >&2
    usage
  fi
  if ! valid_cli "$REVIEWER_CLI"; then
    echo "error: --reviewer must be claude, codex, cursor, or gemini (got: $REVIEWER_CLI)" >&2
    usage
  fi

  _CODER_EFF_MODEL="$(effective_model "$CODER_CLI" "$CODER_MODEL")"
  _PLANNER_EFF_MODEL="$(effective_model "$PLANNER_CLI" "$PLANNER_MODEL")"
  _REVIEWER_EFF_MODEL="$(effective_model "$REVIEWER_CLI" "$REVIEWER_MODEL")"
  if [[ "$CODER_CLI" == "$REVIEWER_CLI" && "$_CODER_EFF_MODEL" == "$_REVIEWER_EFF_MODEL" ]]; then
    echo "error: coder and reviewer must differ; use different CLIs or different models" >&2
    exit 1
  fi
  if [[ "$PLANNER_CLI" == "$REVIEWER_CLI" && "$_PLANNER_EFF_MODEL" == "$_REVIEWER_EFF_MODEL" ]]; then
    echo "error: planner and reviewer must differ; use different CLIs or different models" >&2
    exit 1
  fi

  PLANNER_MATCHES_CODER=false
  if [[ "$PLANNER_CLI" == "$CODER_CLI" && "$_PLANNER_EFF_MODEL" == "$_CODER_EFF_MODEL" ]]; then
    PLANNER_MATCHES_CODER=true
  fi

  if [[ -n "$BRANCH" && "$USE_CURRENT_BRANCH" == true ]]; then
    echo "error: --branch and --current-branch are mutually exclusive" >&2
    exit 1
  fi
  if [[ "$AUTO_BRANCH" == true && ( -n "$BRANCH" || "$USE_CURRENT_BRANCH" == true ) ]]; then
    echo "error: --auto-branch is mutually exclusive with --branch and --current-branch" >&2
    exit 1
  fi
  if [[ "$USE_WORKTREE" == true && "$USE_CURRENT_BRANCH" == true ]]; then
    echo "error: --worktree does not support --current-branch; pass --branch <name> instead" >&2
    exit 1
  fi

  if [[ "$MODE_SET" == true ]]; then
    case "$MODE" in
      plan|plan-review|code|code-review) ;;
      *)
        echo "error: --mode must be plan, plan-review, code, or code-review (got: $MODE)" >&2
        usage
        ;;
    esac
  else
    MODE="all"
  fi

  if [[ -z "$PROMPT" ]]; then
    if [[ "$AUTO_BRANCH" == true ]] || prompt_required_for_mode "$MODE"; then
      echo "error: prompt is required" >&2
      usage
    fi
  fi
}

# Verify the required external commands exist.
check_dependencies() {
  command -v git >/dev/null || { echo "git not found in PATH" >&2; exit 127; }
  command -v gh  >/dev/null || { echo "gh not found in PATH"  >&2; exit 127; }
  if [[ "$CODER_CLI" == "claude" || "$PLANNER_CLI" == "claude" || "$REVIEWER_CLI" == "claude" ]]; then
    command -v claude >/dev/null || { echo "claude not found in PATH" >&2; exit 127; }
  fi
  if [[ "$CODER_CLI" == "codex" || "$PLANNER_CLI" == "codex" || "$REVIEWER_CLI" == "codex" ]]; then
    command -v codex >/dev/null || { echo "codex not found in PATH" >&2; exit 127; }
  fi
  if [[ "$CODER_CLI" == "cursor" || "$PLANNER_CLI" == "cursor" || "$REVIEWER_CLI" == "cursor" ]]; then
    command -v cursor-agent >/dev/null || { echo "cursor-agent not found in PATH" >&2; exit 127; }
  fi
  if [[ "$CODER_CLI" == "gemini" || "$PLANNER_CLI" == "gemini" || "$REVIEWER_CLI" == "gemini" ]]; then
    command -v gemini >/dev/null || { echo "gemini not found in PATH" >&2; exit 127; }
  fi
}

# Print the chosen workflow configuration.
print_configuration() {
  echo "Coder:    ${CODER_CLI}${CODER_MODEL:+ (model: $CODER_MODEL)}"
  echo "Planner:  ${PLANNER_CLI}${PLANNER_MODEL:+ (model: $PLANNER_MODEL)}"
  echo "Reviewer: ${REVIEWER_CLI}${REVIEWER_MODEL:+ (model: $REVIEWER_MODEL)}"
  echo "Prompt:   $PROMPT"
  echo
}

# Prepare CLI argument arrays and workflow constants.
initialize_runtime_state() {
  MAX_TRIES="${MAX_TRIES:-20}"
  SLEEP_SECS="${SLEEP_SECS:-0.2}"
  CODEX_BASE_ARGS="--sandbox workspace-write -a never"
  LOG_CONTEXT_READY=false
  LOG_DIR=""
  REVIEW_LOOP_ATTEMPT=0
  declare -gA LOG_SEQUENCE_COUNTER=()

  build_cursor_args "$CODER_MODEL" CODER_CURSOR_ARGS
  build_cursor_args "$PLANNER_MODEL" PLANNER_CURSOR_ARGS
  build_cursor_args "$REVIEWER_MODEL" REVIEWER_CURSOR_ARGS
  build_model_args "$CODER_MODEL" CODER_CLAUDE_MODEL CODER_CODEX_MODEL CODER_GEMINI_MODEL
  build_model_args "$PLANNER_MODEL" PLANNER_CLAUDE_MODEL PLANNER_CODEX_MODEL PLANNER_GEMINI_MODEL
  build_model_args "$REVIEWER_MODEL" REVIEWER_CLAUDE_MODEL REVIEWER_CODEX_MODEL REVIEWER_GEMINI_MODEL
}

# Prepare the branch checkout or worktree before workflow execution.
prepare_branch_checkout() {
  resolve_target_branch_name

  if [[ "$USE_WORKTREE" == true ]]; then
    REPO_ROOT="$(resolve_repo_root)"
    DEFAULT_START_REF="$(resolve_default_start_ref)"
    SOURCE_CHECKOUT_PATH="$(pwd -P)"
    WORKTREE_PATH="$(resolve_worktree_path "$REPO_ROOT" "$BRANCH")"

    if [[ "$AUTO_BRANCH" == true ]]; then
      echo "Using auto branch worktree: $BRANCH"
    else
      echo "Using worktree for branch: $BRANCH"
    fi
    echo "Worktree path: $WORKTREE_PATH"
    ensure_worktree_for_branch "$BRANCH" "$WORKTREE_PATH" "$DEFAULT_START_REF" "$SOURCE_CHECKOUT_PATH"
    cd "$WORKTREE_PATH"
    return 0
  fi

  if [[ "$USE_CURRENT_BRANCH" == true ]]; then
    echo "Using current branch: $BRANCH"
    return 0
  fi

  if [[ "$AUTO_BRANCH" == true ]]; then
    echo "Using auto branch: $BRANCH"
  fi

  guard_dirty_non_worktree_branch_switch "$(pwd -P)" "$BRANCH"

  if git show-ref --verify --quiet "refs/heads/$BRANCH"; then
    echo "Switching to branch: $BRANCH"
    git checkout "$BRANCH"
  else
    echo "Creating branch: $BRANCH"
    git checkout -b "$BRANCH"
  fi
}

# Resolve branch-scoped artifact paths after branch setup.
resolve_artifact_paths() {
  ARTIFACT_ROOT="${ARTIFACT_ROOT:-$ARTIFACT_ROOT_DEFAULT}"
  BRANCH_PATH="$(resolve_branch_artifact_slug "$BRANCH" "$ARTIFACT_ROOT")"
  PLAN_PATH="${ARTIFACT_ROOT}/branches/${BRANCH_PATH}/plan.md"
  PLAN_FILE="${ARTIFACT_ROOT}/branches/${BRANCH_PATH}/plan-review.md"
  CODE_FILE="${ARTIFACT_ROOT}/branches/${BRANCH_PATH}/code-review.md"
}

# Refresh artifact paths after agent steps may have created a legacy branch directory.
refresh_artifact_paths() {
  resolve_artifact_paths
}

# Validate mode-specific artifact prerequisites.
validate_mode_prerequisites() {
  if [[ "$MODE" == "plan-review" && ! -f "$PLAN_PATH" ]]; then
    echo "error: --mode plan-review requires an existing plan for this branch; run --mode plan first" >&2
    exit 1
  fi
  if [[ "$MODE" == "code" && ! -f "$PLAN_PATH" ]]; then
    echo "error: --mode code requires an approved plan for this branch; run --mode plan first" >&2
    exit 1
  fi
}

# Run the selected workflow mode.
run_selected_mode() {
  case "$MODE" in
    plan)
      echo
      echo "Planner is planning..."
      run_plan

      echo "Reviewer is reviewing the plan..."
      run_plan_review
      echo "AI Can Do It finished the workflow."
      return 0
      ;;
    plan-review)
      if [[ ! -f "$PLAN_FILE" ]]; then
        echo
        echo "Reviewer is reviewing the plan..."
        run_plan_review
        refresh_artifact_paths
      fi
      review_loop "Plan" "$PLAN_FILE" run_plan_update run_plan_review_loop "Planner"
      echo "AI Can Do It finished the workflow."
      return 0
      ;;
    code)
      echo
      echo "Coder is implementing..."
      run_code

      echo "Reviewer is reviewing the code..."
      run_code_review
      echo "AI Can Do It finished the workflow."
      return 0
      ;;
    code-review)
      if [[ ! -f "$CODE_FILE" ]]; then
        echo
        echo "Reviewer is reviewing the code..."
        run_code_review
        refresh_artifact_paths
      fi
      review_loop "Code" "$CODE_FILE" run_code_fix run_code_review_loop "Coder"
      echo "AI Can Do It finished the workflow."
      return 0
      ;;
  esac

  echo
  echo "Planner is planning..."
  run_plan
  refresh_artifact_paths

  echo "Reviewer is reviewing the plan..."
  run_plan_review
  refresh_artifact_paths

  review_loop "Plan" "$PLAN_FILE" run_plan_update run_plan_review_loop "Planner"

  echo
  echo "Coder is implementing..."
  run_code

  echo "Reviewer is reviewing the code..."
  run_code_review
  refresh_artifact_paths

  review_loop "Code" "$CODE_FILE" run_code_fix run_code_review_loop "Coder"

  echo "AI Can Do It finished the workflow."
}

# Run the launcher.
main() {
  CODER=""
  REVIEWER=""
  PLANNER=""
  BRANCH=""
  USE_CURRENT_BRANCH=false
  AUTO_BRANCH=false
  MODE=""
  MODE_SET=false
  VERBOSE=false
  USE_WORKTREE=false
  PROMPT=""

  echo "AI Can Do It"
  echo

  parse_args "$@"
  validate_args
  print_configuration
  check_dependencies
  initialize_runtime_state
  prepare_branch_checkout
  resolve_artifact_paths
  validate_mode_prerequisites
  run_selected_mode
}

if [[ "${BASH_SOURCE[0]}" == "$0" ]]; then
  main "$@"
fi
